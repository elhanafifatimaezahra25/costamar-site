# Copiez ce fichier en .env (ou définissez ces variables sur votre hébergeur)
# et ne committez jamais le vrai .env dans Git.

# ---- Base de données MariaDB ----
DB_URL=jdbc:mariadb://localhost:3306/costamar
DB_USERNAME=costamar
DB_PASSWORD=costamar

# ---- JWT ----
# Générez une longue chaîne aléatoire pour la prod, ex: openssl rand -base64 48
JWT_SECRET=changeThisSecretInProductionToSomethingLongAndRandom1234567890
JWT_EXPIRATION_MS=86400000

# ---- Compte admin créé au premier démarrage ----
ADMIN_EMAIL=admin@costamar-hammam.com
ADMIN_PASSWORD=ChangeMe123!

# ---- Email (SMTP) pour les emails de confirmation ----
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=contact@costamar-hammam.com

# ---- Divers ----
PORT=8080
SPRING_PROFILES_ACTIVE=prod
DDL_AUTO=update
